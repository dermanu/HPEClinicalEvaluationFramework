import os
import re

# Specify the directory where your files are located
directory = 'path_to_your_directory'

# Loop through each file in the directory
for filename in os.listdir(directory):
    # Check if the file name matches the first pattern (mediapipe-complex-background10.pkl)
    match = re.match(r'^(mediapipe-complex-background)(\d+)(\.pkl)$', filename)
    if match:
        new_filename = f"{match.group(1)}-{match.group(2)}{match.group(3)}"
        os.rename(os.path.join(directory, filename), os.path.join(directory, new_filename))
        print(f"Renamed: {filename} -> {new_filename}")

    # Check if the file name matches the second pattern (-camera_09.pkl)
    match_camera = re.match(r'^(-camera_)(\d)(\d)(\.pkl)$', filename)
    if match_camera:
        new_filename = f"{match_camera.group(1)}{match_camera.group(2)}-{match_camera.group(3)}{match_camera.group(4)}"
        os.rename(os.path.join(directory, filename), os.path.join(directory, new_filename))
        print(f"Renamed: {filename} -> {new_filename}")